generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ProfileRole {
  admin
  member
}

enum ProjectMembershipRole {
  viewer
  editor
  manager
  member
}

enum ProfileAccessStatus {
  active
  pending
  disabled
}

enum ProjectInvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum AccessRequestStatus {
  pending
  approved
  rejected
  cancelled
}

enum TaskStatus {
  new
  in_review
  in_discussion
  blocked
  done
}

model Profile {
  id              String             @id @db.Uuid
  email           String             @unique
  displayName     String             @map("display_name")
  role            ProfileRole
  accessStatus    ProfileAccessStatus @default(active) @map("access_status")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdProjects Project[]          @relation("ProjectCreatedBy")
  updatedProjects Project[]          @relation("ProjectUpdatedBy")
  createdTasks    Task[]             @relation("TaskCreatedBy")
  updatedTasks    Task[]             @relation("TaskUpdatedBy")
  assignedTasks   Task[]             @relation("TaskAssignedTo")
  uploadedFiles   File[]             @relation("FileUploadedBy")
  projectMemberships ProjectMembership[]
  acceptedInvitations ProjectInvitation[] @relation("InvitationAcceptedBy")
  accessRequests AccessRequest[] @relation("AccessRequestProfile")
  reviewedAccessRequests AccessRequest[] @relation("AccessRequestReviewedBy")
  heldEditLeases EditLease[] @relation("EditLeaseHolder")
  preference      ProfilePreference?

  @@map("profiles")
}

model Project {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  creator   Profile?  @relation("ProjectCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater   Profile?  @relation("ProjectUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  memberships ProjectMembership[]
  invitations ProjectInvitation[]
  accessRequests AccessRequest[]
  editLeases EditLease[]
  tasks     Task[]
  files     File[]
  workTypeDefinitions WorkTypeDefinition[]

  @@map("projects")
}

model Task {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId          String      @map("project_id") @db.Uuid
  taskNumber         Int         @map("task_number")
  actionId           Int         @default(0) @map("action_id")
  issueId            String      @default("") @map("issue_id")
  parentTaskId       String?     @map("parent_task_id") @db.Uuid
  rootTaskId         String      @map("root_task_id") @db.Uuid
  depth              Int         @default(0)
  siblingOrder       Int         @default(0) @map("sibling_order")
  dueDate            String      @default("") @map("due_date")
  category           String      @default("")
  coordinationScope  String      @default("") @map("coordination_scope")
  ownerDiscipline    String      @default("") @map("owner_discipline")
  requester          String      @default("")
  relatedDisciplines String      @default("") @map("related_disciplines")
  assignee           String      @default("")
  assigneeProfileId  String?     @map("assignee_profile_id") @db.Uuid
  title              String
  reviewedAt         String      @default("") @map("reviewed_at")
  isDaily            Boolean     @default(false) @map("is_daily")
  locationRef        String      @default("") @map("location_ref")
  calendarLinked     Boolean     @default(false) @map("calendar_linked")
  description        String      @default("")
  status             TaskStatus  @default(new)
  statusHistory      String      @default("") @map("status_history")
  conclusion         String      @default("")
  completedAt        DateTime?   @map("completed_at") @db.Timestamptz(6)
  version            Int         @default(1)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy          String?     @map("created_by") @db.Uuid
  updatedBy          String?     @map("updated_by") @db.Uuid
  deletedAt          DateTime?   @map("deleted_at") @db.Timestamptz(6)
  purgedAt           DateTime?   @map("purged_at") @db.Timestamptz(6)
  project            Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent             Task?       @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children           Task[]      @relation("TaskHierarchy")
  rootTask           Task        @relation("TaskRoot", fields: [rootTaskId], references: [id], onDelete: Restrict)
  rootRefs           Task[]      @relation("TaskRoot")
  creator            Profile?    @relation("TaskCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater            Profile?    @relation("TaskUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  assigneeProfile    Profile?    @relation("TaskAssignedTo", fields: [assigneeProfileId], references: [id], onDelete: SetNull)
  files              File[]

  @@unique([projectId, taskNumber])
  @@index([projectId, deletedAt, purgedAt])
  @@index([projectId, assigneeProfileId])
  @@index([parentTaskId])
  @@map("tasks")
}

model File {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId          String    @map("task_id") @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  fileGroupId     String    @map("file_group_id") @db.Uuid
  originalName    String    @map("original_name")
  mimeType        String?   @map("mime_type")
  sizeBytes       BigInt    @map("size_bytes")
  storageProvider String    @default("supabase-storage") @map("storage_provider")
  storageBucket   String    @map("storage_bucket")
  objectPath      String    @map("object_path")
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  uploadedBy      String?   @map("uploaded_by") @db.Uuid
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  purgedAt        DateTime? @map("purged_at") @db.Timestamptz(6)
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader        Profile?  @relation("FileUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([taskId, deletedAt, purgedAt])
  @@index([projectId, deletedAt, purgedAt])
  @@unique([fileGroupId, version])
  @@map("files")
}

model ProfilePreference {
  profileId            String   @id @map("profile_id") @db.Uuid
  themeId              String   @default("classic") @map("theme_id")
  quickCreateWidths    Json     @default("{}") @map("quick_create_widths")
  taskListColumnWidths Json     @default("{}") @map("task_list_column_widths")
  taskListRowHeights   Json     @default("{}") @map("task_list_row_heights")
  taskListDetailPanelWidth Int  @default(340) @map("task_list_detail_panel_width")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile              Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_preferences")
}

model FoundationSetting {
  id              String   @id @default("global")
  ownerDiscipline String   @default("건축") @map("owner_discipline")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy       String?  @map("updated_by") @db.Uuid

  @@map("foundation_settings")
}

model ProjectMembership {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String                @map("project_id") @db.Uuid
  profileId   String                @map("profile_id") @db.Uuid
  role        ProjectMembershipRole @default(editor)
  displayName String                @default("") @map("display_name")
  email       String                @default("")
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   String?               @map("created_by") @db.Uuid
  updatedBy   String?               @map("updated_by") @db.Uuid
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profile     Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([projectId, profileId])
  @@index([profileId])
  @@map("project_memberships")
}

model ProjectInvitation {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId           String                  @map("project_id") @db.Uuid
  email               String
  role                ProjectMembershipRole
  status              ProjectInvitationStatus @default(pending)
  tokenHash           String                  @unique @map("token_hash")
  expiresAt           DateTime                @map("expires_at") @db.Timestamptz(6)
  acceptedByProfileId String?                 @map("accepted_by_profile_id") @db.Uuid
  acceptedAt          DateTime?               @map("accepted_at") @db.Timestamptz(6)
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy           String?                 @map("created_by") @db.Uuid
  updatedBy           String?                 @map("updated_by") @db.Uuid
  project             Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  acceptedBy          Profile?                @relation("InvitationAcceptedBy", fields: [acceptedByProfileId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([email])
  @@index([expiresAt])
  @@map("project_invitations")
}

model AccessRequest {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId     String                @map("profile_id") @db.Uuid
  email         String
  projectId     String?               @map("project_id") @db.Uuid
  message       String?
  status        AccessRequestStatus   @default(pending)
  requestedRole ProjectMembershipRole @default(viewer) @map("requested_role")
  reviewedBy    String?               @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?             @map("reviewed_at") @db.Timestamptz(6)
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile       Profile               @relation("AccessRequestProfile", fields: [profileId], references: [id], onDelete: Cascade)
  project       Project?              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer      Profile?              @relation("AccessRequestReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([profileId, status])
  @@index([projectId, status])
  @@index([email])
  @@map("access_requests")
}

model EditLease {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  targetType        String   @map("target_type")
  targetId          String   @map("target_id") @db.Uuid
  fieldKey          String   @map("field_key")
  holderProfileId   String   @map("holder_profile_id") @db.Uuid
  holderDisplayName String   @default("") @map("holder_display_name")
  expiresAt         DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  holder            Profile  @relation("EditLeaseHolder", fields: [holderProfileId], references: [id], onDelete: Cascade)

  @@unique([projectId, targetType, targetId, fieldKey])
  @@index([expiresAt])
  @@index([holderProfileId])
  @@map("edit_leases")
}

model WorkTypeDefinition {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fieldKey  String    @default("workType") @map("field_key")
  projectId String?   @map("project_id") @db.Uuid
  code      String
  labelKo   String    @map("label_ko")
  labelEn   String    @map("label_en")
  isSystem  Boolean   @default(false) @map("is_system")
  isActive  Boolean   @default(true) @map("is_active")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([fieldKey, projectId, isActive])
  @@index([fieldKey, projectId, sortOrder])
  @@map("work_type_definitions")
}
