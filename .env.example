# Select the backend mode for this environment.
# local: local JSON data + local uploads + auth stub
# firestore: Firestore metadata + local uploads + auth stub
# cloud: Supabase Auth + Postgres + Supabase Storage
APP_BACKEND_MODE=local

# Data guard policy
# strict: block risky writes unless DATA_GUARD_CONFIRM matches the active lock token
# warn: log the warning and allow the write to continue
DATA_GUARD_MODE=strict
DATA_GUARD_CONFIRM=

# Local-first development defaults
# Set LOCAL_DATA_ROOT to writable persistent storage in deployed Node environments
# if you want the holiday cache to survive restarts and scale-out.
LOCAL_DATA_ROOT=D:\architect-start-data
LOCAL_UPLOAD_ROOT=D:\architect-start-data\uploads
LOCAL_PROJECT_META_PATH=D:\architect-start-data\project\project-meta.json
DEFAULT_PROJECT_NAME=Architect Start
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_UPLOAD_EXTENSIONS=pdf,dwg,dxf,xlsx,xls,doc,docx,ppt,pptx,png,jpg,jpeg,webp,txt,csv,zip
HOLIDAY_API_SERVICE_KEY=

# Cloud backend only
DATABASE_URL=
DIRECT_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=task-files
SUPABASE_PROJECT_REF=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# Optional Firestore development mode
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
