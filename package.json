{
  "name": "architect-start2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"let pkg=process.env.npm_package_json||'';if(pkg.charCodeAt(0)===92&&pkg.charCodeAt(1)===92&&pkg.charCodeAt(2)===63&&pkg.charCodeAt(3)===92){pkg=pkg.slice(4)};const path=require('node:path');require(path.join(path.dirname(pkg||process.cwd()),'scripts','run-next.cjs')).runNext(['dev','--webpack'])\"",
    "build": "node -e \"let pkg=process.env.npm_package_json||'';if(pkg.charCodeAt(0)===92&&pkg.charCodeAt(1)===92&&pkg.charCodeAt(2)===63&&pkg.charCodeAt(3)===92){pkg=pkg.slice(4)};const path=require('node:path');require(path.join(path.dirname(pkg||process.cwd()),'scripts','run-next.cjs')).runNext(['build'])\"",
    "start": "node -e \"let pkg=process.env.npm_package_json||'';if(pkg.charCodeAt(0)===92&&pkg.charCodeAt(1)===92&&pkg.charCodeAt(2)===63&&pkg.charCodeAt(3)===92){pkg=pkg.slice(4)};const path=require('node:path');require(path.join(path.dirname(pkg||process.cwd()),'scripts','run-next.cjs')).runNext(['start'])\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "node scripts/blocked-direct-command.mjs db:push \"Use npm run db:migrate:safe instead.\"",
    "db:migrate": "tsx scripts/db-migrate-safe.ts",
    "db:migrate:safe": "tsx scripts/db-migrate-safe.ts",
    "db:seed": "tsx scripts/db-seed-safe.ts",
    "db:seed:safe": "tsx scripts/db-seed-safe.ts",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts",
    "import:legacy": "tsx scripts/import-legacy-safe.ts",
    "import:legacy:safe": "tsx scripts/import-legacy-safe.ts",
    "data:doctor": "tsx scripts/data-doctor.ts",
    "data:backup": "tsx scripts/data-backup.ts",
    "data:rekey-issue-ids": "tsx scripts/rekey-project-issue-ids.ts",
    "data:restore": "tsx scripts/data-restore.ts",
    "task-export:verify": "tsx scripts/task-export-verify.ts",
    "codex:skills:list": "powershell -ExecutionPolicy Bypass -File scripts/sync-project-skills.ps1 -List",
    "codex:skills:sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-project-skills.ps1",
    "ui-copy:validate": "powershell -ExecutionPolicy Bypass -File scripts/ui-copy-validate.ps1",
    "ui-copy:watch": "powershell -ExecutionPolicy Bypass -File scripts/ui-copy-validate.ps1 -Watch",
    "ui-copy:report": "node --experimental-strip-types scripts/ui-copy-report.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "firebase": "12.9.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.36.0",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.6.2",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
